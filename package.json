{
  "name": "data-360-sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript SDK for the Salesforce Data 360 Connect REST API",
  "author": "javrrr",
  "repository": {
    "type": "git",
    "url": "https://github.com/javrrr/data-360-sdk.git"
  },
  "homepage": "https://github.com/javrrr/data-360-sdk#readme",
  "bugs": {
    "url": "https://github.com/javrrr/data-360-sdk/issues"
  },
  "keywords": [
    "salesforce",
    "data-360",
    "data-cloud",
    "cdp",
    "sdk",
    "typescript",
    "api",
    "openapi",
    "connect-api"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      },
      "require": {
        "types": "./dist/schemas.d.cts",
        "default": "./dist/schemas.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/generate-types.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "openapi-typescript": "^7.6.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yaml": "^2.6.1"
  },
  "license": "MIT"
}
